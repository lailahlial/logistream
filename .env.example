# ═══════════════════════════════════════════════════════
#  LogiStream Control Tower – Configuration
#  Copiez ce fichier en .env et remplissez vos valeurs
# ═══════════════════════════════════════════════════════

# ── LLM Provider ────────────────────────────────────────
# Choisir : groq | openai | mock
LLM_PROVIDER=groq

# Groq (recommandé – gratuit) : https://console.groq.com
GROQ_API_KEY=gsk_your_groq_api_key_here

# OpenAI (alternative)
OPENAI_API_KEY=sk-your_openai_key_here

# ── Simulation ───────────────────────────────────────────
# Facteur d'accélération temps : 360 = 1h réelle → 10s simulation
TIME_ACCELERATION=360

# ── Seuil retard (minutes) ───────────────────────────────
DELAY_THRESHOLD_MINUTES=30
